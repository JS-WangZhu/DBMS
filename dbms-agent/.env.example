# API Key for authentication (must match main project)
AGENT_API_KEY=your-agent-api-key-here

# Flask configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Agent settings
AGENT_HOST=0.0.0.0
AGENT_PORT=5001
AGENT_DEBUG=false

# Logging
LOG_LEVEL=INFO

# Backup tool paths (optional, defaults to system PATH)
# MYSQLDUMP_PATH=/usr/bin/mysqldump
# MONGODUMP_PATH=/usr/bin/mongodump
