FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
FERNET_KEY=
DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/dbms_meta
AUTH_MODE=local
LDAP_SERVER_URI=
LDAP_BASE_DN=
LDAP_USER_DN_TEMPLATE=
SSO_ENABLED=false
SSO_PROVIDER_NAME=SSO
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_AUTHORIZE_URL=
SSO_TOKEN_URL=
SSO_USERINFO_URL=
SSO_SCOPE=openid profile email
SSO_REDIRECT_URI=
SSO_USERNAME_FIELD=preferred_username
SSO_EMAIL_FIELD=email
AUTO_BOOTSTRAP_ADMIN=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
ENABLE_SCHEDULER=true
WECHAT_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=
SMTP_TO=
BACKUP_NOTIFY_CHANNELS=wecom,email
MONITOR_COLLECT_WORKERS=8
# Backup tools paths
# Set full paths to backup tools if they are not in system PATH
MYSQLDUMP_PATH=mysqldump
MONGODUMP_PATH=mongodump
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true 
